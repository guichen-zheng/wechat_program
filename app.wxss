page {
  height: 100vh;
  background: #F5F7FA;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.scroll-main {
  flex: 1;
  overflow-y: hidden;
}

/* ---- 通用卡片 ---- */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}

/* ---- 通用按钮 ---- */
.btn-primary {
  background: #1677FF;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after { border: none; }

.btn-ghost {
  background: transparent;
  color: #1677FF;
  border: 2rpx solid #1677FF;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-ghost::after { border: none; }

/* ---- 分割线 ---- */
.divider {
  height: 1rpx;
  background: #E8E8E8;
  margin: 0 32rpx;
}

.divider-bold {
  height: 12rpx;
  background: #F5F7FA;
}

/* ---- 行 ---- */
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.row-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* ---- 标签 ---- */
.tag {
  font-size: 22rpx;
  color: #fff;
  background: #FF6B35;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  margin-left: 12rpx;
}

.tag-blue {
  background: #1677FF;
}
