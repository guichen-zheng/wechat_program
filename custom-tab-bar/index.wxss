.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  display: flex;
  flex-direction: row;
  z-index: 999;
}

.tab-bar__border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: #E8E8E8;
}

.tab-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tab-bar__icon-text {
  font-size: 44rpx;
  line-height: 1;
}

.tab-bar__text {
  font-size: 22rpx;
  color: #999;
  line-height: 1;
}

.tab-bar__text--active {
  color: #1677FF;
}
