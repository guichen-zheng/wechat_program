<view class="page-root">
  <view class="nav-bar">
    <view class="nav-back" bindtap="onTapBack">
      <text class="nav-back-arrow">‹</text>
    </view>
    <text class="nav-title">预约服务</text>
  </view>

  <!-- 顶部分类切换 -->
  <scroll-view scroll-x show-scrollbar="{{false}}" class="cat-tabs">
    <view class="cat-tabs-inner">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="cat-tab {{index === activeCat ? 'cat-tab--active' : ''}}"
        data-index="{{index}}"
        bindtap="onTapCategory"
      >
        <text class="cat-tab-text">{{item.name}}</text>
        <view wx:if="{{index === activeCat}}" class="cat-tab-bar"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 主体：左二级分类 + 右项目列表 -->
  <view class="body">
    <!-- 左侧二级分类 -->
    <scroll-view scroll-y show-scrollbar="{{false}}" class="sub-col">
      <view
        wx:for="{{subCategories}}"
        wx:key="name"
        class="sub-item {{index === activeSub ? 'sub-item--active' : ''}}"
        data-index="{{index}}"
        bindtap="onTapSub"
      >
        <text class="sub-text">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧项目列表 -->
    <scroll-view scroll-y type="list" show-scrollbar="{{false}}" class="item-col">
      <view class="item-col-title">{{subCategories[activeSub].name}}</view>

      <view
        wx:for="{{items}}"
        wx:key="id"
        class="svc-card"
        data-id="{{item.id}}"
        bindtap="goDetail"
      >
        <view class="svc-thumb">
          <text class="svc-thumb-emoji">{{categories[activeCat].emoji}}</text>
        </view>
        <view class="svc-info">
          <text class="svc-name">{{item.name}}</text>
          <text wx:if="{{item.desc}}" class="svc-desc">{{item.desc}}</text>
          <view class="svc-price-row">
            <view class="svc-price-line">
              <text class="svc-price">¥{{item.price}}</text>
              <text wx:if="{{item.originPrice}}" class="svc-origin">¥{{item.originPrice}}</text>
            </view>
            <view wx:if="{{item.memberPrice !== null}}" class="svc-member">
              <text class="svc-member-label">大会员</text>
              <text class="svc-member-price">¥{{item.memberPrice}}</text>
            </view>
            <view wx:if="{{item.save}}" class="svc-save">
              <text class="svc-save-text">立省¥{{item.save}}</text>
            </view>
          </view>
          <view wx:if="{{item.tag && item.tag !== '随机立减'}}" class="svc-tag">
            <text class="svc-tag-text">{{item.tag}}</text>
          </view>
        </view>
        <view class="svc-right">
          <view class="svc-buy" data-id="{{item.id}}" catchtap="goDetail">
            <text>{{categories[activeCat].key === 'package' ? '抢购' : '购买'}}</text>
          </view>
          <text wx:if="{{item.sold}}" class="svc-sold">已售{{item.sold}}</text>
        </view>
      </view>

      <view style="height:40rpx;"></view>
    </scroll-view>
  </view>
</view>
