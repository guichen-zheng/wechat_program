page { background: #F5F7FA; }

.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: calc(44px + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  background: #fff;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  position: relative;
  box-shadow: 0 1rpx 0 #F0F0F0;
}

.nav-back {
  width: 60rpx;
  height: 44px;
  display: flex;
  align-items: center;
}

.nav-back-arrow {
  font-size: 48rpx;
  color: #333;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

/* ---- 顶部分类 ---- */
.cat-tabs {
  background: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #F0F0F0;
}

.cat-tabs-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 12rpx;
}

.cat-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx 16rpx;
  position: relative;
}

.cat-tab-text {
  font-size: 30rpx;
  color: #666;
}

.cat-tab--active .cat-tab-text {
  color: #FF1F1F;
  font-weight: bold;
  font-size: 32rpx;
}

.cat-tab-bar {
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #FF1F1F;
  margin-top: 10rpx;
}

/* ---- 主体两栏 ---- */
.body {
  flex: 1;
  display: flex;
  flex-direction: row;
  overflow: hidden;
}

.sub-col {
  width: 180rpx;
  background: #F5F7FA;
  overflow-y: hidden;
}

.sub-item {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  text-align: center;
  border-left: 6rpx solid transparent;
}

.sub-item--active {
  background: #fff;
  border-left-color: #FF1F1F;
}

.sub-text {
  font-size: 26rpx;
  color: #666;
}

.sub-item--active .sub-text {
  color: #FF1F1F;
  font-weight: bold;
}

.item-col {
  flex: 1;
  background: #fff;
  overflow-y: hidden;
}

.item-col-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 24rpx 8rpx;
}

/* ---- 项目卡片 ---- */
.svc-card {
  display: flex;
  flex-direction: row;
  padding: 24rpx;
  border-bottom: 1rpx solid #F2F2F2;
}

.svc-thumb {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #FFF0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.svc-thumb-emoji {
  font-size: 64rpx;
}

.svc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 16rpx;
  min-width: 0;
}

.svc-name {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  line-height: 1.35;
}

.svc-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.3;
}

.svc-price-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-top: 12rpx;
}

.svc-price-line {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.svc-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #FF1F1F;
  white-space: nowrap;
}

.svc-origin {
  font-size: 24rpx;
  color: #BFBFBF;
  text-decoration: line-through;
  margin-left: 12rpx;
  white-space: nowrap;
}

.svc-save {
  align-self: flex-start;
  margin-top: 8rpx;
  border: 1rpx solid #FF4D4F;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.svc-save-text {
  font-size: 20rpx;
  color: #FF4D4F;
}

.svc-member {
  display: flex;
  flex-direction: row;
  align-items: center;
  align-self: flex-start;
  margin-top: 8rpx;
  background: linear-gradient(90deg, #3A3A3A, #1A1A1A);
  border-radius: 6rpx;
  overflow: hidden;
}

.svc-member-label {
  font-size: 20rpx;
  color: #F6D98A;
  padding: 4rpx 8rpx;
}

.svc-member-price {
  font-size: 22rpx;
  color: #F6D98A;
  font-weight: bold;
  padding: 4rpx 10rpx 4rpx 0;
}

.svc-tag {
  margin-top: 10rpx;
  align-self: flex-start;
  border: 1rpx solid #FF7A45;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.svc-tag-text {
  font-size: 20rpx;
  color: #FF7A45;
}

.svc-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
  padding-left: 8rpx;
}

.svc-buy {
  background: #FF1F1F;
  border-radius: 28rpx;
  padding: 10rpx 28rpx;
}

.svc-buy text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.svc-sold {
  font-size: 22rpx;
  color: #BFBFBF;
}
