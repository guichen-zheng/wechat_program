page { background: #F5F7FA; }

/* ---- 搜索栏（固定） ---- */
.search-bar-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #FF2D2D 0%, #FF5A5A 100%);
  padding-bottom: 12rpx;
}

.search-inner {
  margin: 10rpx 24rpx 0;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}

.search-icon-text {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #fff;
}

.search-placeholder {
  color: rgba(255,255,255,0.65);
  font-size: 28rpx;
}

/* ---- 搜索联想下拉（独立浮层） ---- */
.search-suggest {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  z-index: 101;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,.15);
}

.suggest-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-emoji {
  font-size: 34rpx;
  margin-right: 20rpx;
}

.suggest-name {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
}

.suggest-arrow {
  font-size: 30rpx;
  color: #BFBFBF;
}

.store-tag {
  margin: 6rpx 24rpx 0;
  display: flex;
  align-items: center;
}

.store-tag-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

/* ---- 主滚动 ---- */
.home-scroll {
  background: linear-gradient(180deg, #FF5A5A 0rpx, #FFB3B3 200rpx, #F5F7FA 460rpx);
}

/* ---- 轮播图 ---- */
.banner-wrap {
  margin: 0 0 20rpx;
  border-radius: 0;
  overflow: hidden;
}

.banner-swiper {
  height: 25vh;
  width: 100%;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* ---- 功能图标（2×4 宫格） ---- */
.feature-grid {
  background: #fff;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 28rpx 8rpx 12rpx;
  margin-bottom: 16rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  padding: 12rpx 0;
}

.feature-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.feature-icon-car { background: #E8F4FF; }
.feature-icon-booking { background: #FFF3E0; }
.feature-icon-recharge { background: #E8F5E9; }
.feature-icon-record { background: #FFF8E1; }
.feature-icon-location { background: #FCE4EC; }
.feature-icon-beauty { background: #F3E8FF; }
.feature-icon-tire { background: #ECEFF1; }
.feature-icon-maintain { background: #FFEFE6; }
.feature-icon-package { background: #FFEAEA; }

.feature-icon-emoji {
  font-size: 44rpx;
}

.feature-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  line-height: 1.3;
}

/* ---- 洗车计划 ---- */
.section-title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.section-sub {
  font-size: 24rpx;
  color: #999;
}

.plan-list {
  padding: 0 24rpx;
}

.plan-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.plan-name-row {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.plan-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.plan-tag {
  margin-left: 12rpx;
  background: #FF6B35;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.plan-tag text {
  font-size: 20rpx;
  color: #fff;
}

.plan-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B35;
  white-space: nowrap;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.plan-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: block;
}

.plan-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

.plan-duration {
  font-size: 24rpx;
  color: #999;
}

.plan-arrow {
  font-size: 26rpx;
  color: #FF1F1F;
}
