<scroll-view scroll-y style="height:100vh;" type="list">
  <view class="login-page">
    <!-- Logo区 -->
    <view class="logo-area">
      <view class="logo-circle">
        <text class="logo-text">洗</text>
      </view>
      <text class="app-name">天猫洗车</text>
      <text class="app-slogan">专业洗车，一键预约</text>
    </view>

    <!-- 表单区 -->
    <view class="form-card">
      <text class="form-title">手机号登录</text>

      <view class="input-group">
        <text class="input-label">手机号</text>
        <view class="input-wrap {{phoneFocused ? 'input-wrap--focused' : ''}}">
          <input
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            placeholder-class="input-placeholder"
            bindinput="onPhoneInput"
            bindfocus="onPhoneFocus"
            bindblur="onPhoneBlur"
            value="{{phone}}"
          />
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">密码</text>
        <view class="input-wrap {{pwdFocused ? 'input-wrap--focused' : ''}}">
          <input
            class="input-field"
            password="{{true}}"
            maxlength="20"
            placeholder="请输入密码"
            placeholder-class="input-placeholder"
            bindinput="onPwdInput"
            bindfocus="onPwdFocus"
            bindblur="onPwdBlur"
            value="{{password}}"
          />
        </view>
      </view>

      <button class="btn-primary login-btn" bindtap="login">
        <text>登 录</text>
      </button>

      <view class="register-link" bindtap="goRegister">
        <text class="register-text">没有账号？</text>
        <text class="register-link-text">立即注册</text>
      </view>
    </view>
  </view>
</scroll-view>
