.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1677FF 0%, #0050D0 40%, #F5F7FA 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.logo-text {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
}

.app-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.form-card {
  width: 686rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
  margin-top: 20rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 40rpx;
  display: block;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input-wrap {
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #FAFAFA;
}

.input-wrap--focused {
  border-color: #1677FF;
}

.code-wrap {
  padding-right: 0;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  background: transparent;
}

.input-placeholder {
  color: #BFBFBF;
  font-size: 28rpx;
}

.code-btn {
  height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 2rpx solid #E8E8E8;
  white-space: nowrap;
}

.code-btn text {
  font-size: 26rpx;
  color: #1677FF;
}

.code-btn--disabled text {
  color: #BFBFBF;
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
  background: #1677FF;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.login-btn::after { border: none; }

.register-link {
  display: flex;
  justify-content: center;
  align-items: center;
}

.register-text {
  font-size: 28rpx;
  color: #666;
}

.register-link-text {
  font-size: 28rpx;
  color: #1677FF;
}
