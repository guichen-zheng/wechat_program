<view class="page-root">
  <view class="nav-bar">
    <view wx:if="{{showBack}}" class="nav-back" bindtap="onTapBack">
      <text class="nav-back-arrow">‹</text>
    </view>
    <text class="nav-title">我的车辆</text>
  </view>

  <scroll-view scroll-y type="list" show-scrollbar="{{false}}" style="height:{{scrollViewHeight}}px;">
    <view class="vehicle-list">

      <!-- 已添加车辆 -->
      <view
        wx:for="{{vehicles}}"
        wx:key="full"
        class="vehicle-card"
      >
        <view class="vehicle-icon">🚗</view>
        <view class="vehicle-info">
          <text class="vehicle-plate">{{item.full}}{{item.isNewEnergy ? ' · 新能源' : ''}}</text>
          <text class="vehicle-sub">{{item.carModel || '未选择品牌'}}</text>
        </view>
        <view class="vehicle-del" bindtap="removeVehicle" data-index="{{index}}">
          <text class="vehicle-del-text">删除</text>
        </view>
      </view>

      <!-- 添加车辆按钮 -->
      <view class="add-vehicle-btn" bindtap="addVehicle">
        <text class="add-vehicle-plus">+</text>
        <text class="add-vehicle-text">添加车辆</text>
      </view>

    </view>
    <view style="height:40rpx;"></view>
  </scroll-view>

  <tab-bar />
</view>
