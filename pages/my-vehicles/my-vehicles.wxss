page { background: #F5F7FA; }

.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: calc(44px + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  background: #fff;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  position: relative;
  box-shadow: 0 1rpx 0 #F0F0F0;
}

.nav-back {
  width: 60rpx;
  height: 44px;
  display: flex;
  align-items: center;
}

.nav-back-arrow {
  font-size: 48rpx;
  color: #333;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.vehicle-list {
  padding: 24rpx;
}

.vehicle-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05);
}

.vehicle-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.vehicle-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.vehicle-plate {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 4rpx;
}

.vehicle-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.vehicle-del {
  padding: 10rpx 24rpx;
  border: 2rpx solid #FF4D4F;
  border-radius: 10rpx;
}

.vehicle-del-text {
  font-size: 26rpx;
  color: #FF4D4F;
}

.add-vehicle-btn {
  background: #fff;
  border-radius: 20rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #BFBFBF;
  margin-bottom: 20rpx;
}

.add-vehicle-plus {
  font-size: 60rpx;
  color: #BFBFBF;
  line-height: 1;
  margin-bottom: 12rpx;
}

.add-vehicle-text {
  font-size: 28rpx;
  color: #999;
}
