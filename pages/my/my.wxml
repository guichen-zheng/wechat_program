<view class="my-page" style="padding-top:{{statusBarHeight}}px;">
  <!-- 顶部标题 -->
  <view class="nav-header">
    <text class="nav-title">我的</text>
  </view>

  <scroll-view scroll-y type="list" show-scrollbar="{{false}}" style="height:{{scrollViewHeight}}px;">

    <!-- 账户区 -->
    <view class="account-section" bindtap="chooseAvatar">
      <view class="account-left">
        <text class="account-label">账户</text>
        <text class="account-hint">点击头像可更换</text>
      </view>
      <view class="avatar-wrap">
        <image wx:if="{{user.avatar}}" class="avatar-img" src="{{user.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-plus">+</text>
        </view>
      </view>
    </view>

    <view class="divider-bold"></view>

    <!-- 手机号 -->
    <view class="list-item">
      <text class="list-label">手机号</text>
      <text class="list-value">{{user.phone}}</text>
    </view>
    <view class="divider"></view>

    <!-- 余额 -->
    <view class="list-item">
      <text class="list-label">余额</text>
      <text class="list-value balance-val">¥{{user.balance}}</text>
    </view>
    <view class="divider"></view>

    <!-- 交易记录 -->
    <view class="list-item list-item--arrow" bindtap="goTransactions">
      <text class="list-label">交易记录</text>
      <view class="list-right">
        <text class="list-arrow">›</text>
      </view>
    </view>

    <!-- 退出 -->
    <view class="logout-wrap">
      <view class="logout-btn" bindtap="logout">
        <text class="logout-text">退出账号</text>
      </view>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>

  <tab-bar />
</view>
