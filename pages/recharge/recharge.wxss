page { background: #F5F7FA; }

.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: calc(44px + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  background: #fff;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  position: relative;
  box-shadow: 0 1rpx 0 #F0F0F0;
}

.nav-back {
  width: 60rpx;
  height: 44px;
  display: flex;
  align-items: center;
}

.nav-back-arrow {
  font-size: 48rpx;
  color: #333;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.balance-hero {
  background: linear-gradient(135deg, #1677FF 0%, #0050D0 100%);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 16rpx;
}

.balance-val {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

.section-card {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
}

.section-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  display: block;
}

.preset-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.preset-item {
  width: calc(25% - 12rpx);
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
}

.preset-item--active {
  border-color: #1677FF;
  background: #EFF6FF;
}

.preset-val {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.preset-item--active .preset-val {
  color: #1677FF;
}

.custom-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-label {
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
}

.custom-input-wrap {
  flex: 1;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background: #FAFAFA;
}

.custom-unit {
  font-size: 28rpx;
  color: #666;
  margin-right: 8rpx;
}

.custom-input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  color: #1A1A1A;
}

.custom-placeholder {
  color: #BFBFBF;
  font-size: 26rpx;
}

.pay-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pay-icon { font-size: 44rpx; }

.pay-name {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
}

.pay-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #1677FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-check text {
  font-size: 24rpx;
  color: #fff;
}

.bottom-bar {
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.06);
}

.recharge-btn {
  background: #07C160;
  color: #fff;
  border-radius: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  width: 100%;
}

.recharge-btn::after { border: none; }

.recharge-btn--loading {
  background: #BFBFBF;
}
