<scroll-view scroll-y style="height:100vh;" type="list">
  <view class="login-page">
    <view class="logo-area">
      <view class="logo-circle">
        <text class="logo-text">洗</text>
      </view>
      <text class="app-name">天猫洗车</text>
      <text class="app-slogan">注册账号，享受专属服务</text>
    </view>

    <view class="form-card">
      <text class="form-title">新用户注册</text>

      <view class="input-group">
        <text class="input-label">手机号</text>
        <view class="input-wrap {{phoneFocused ? 'input-wrap--focused' : ''}}">
          <input
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            placeholder-class="input-placeholder"
            bindinput="onPhoneInput"
            bindfocus="onPhoneFocus"
            bindblur="onPhoneBlur"
            value="{{phone}}"
          />
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">设置密码</text>
        <view class="input-wrap {{pwdFocused ? 'input-wrap--focused' : ''}}">
          <input
            class="input-field"
            password="{{true}}"
            maxlength="20"
            placeholder="请设置密码（至少6位）"
            placeholder-class="input-placeholder"
            bindinput="onPwdInput"
            bindfocus="onPwdFocus"
            bindblur="onPwdBlur"
            value="{{password}}"
          />
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">验证码</text>
        <view class="input-wrap code-wrap {{codeFocused ? 'input-wrap--focused' : ''}}">
          <input
            class="input-field"
            type="number"
            maxlength="6"
            placeholder="6位验证码"
            placeholder-class="input-placeholder"
            bindinput="onCodeInput"
            bindfocus="onCodeFocus"
            bindblur="onCodeBlur"
            value="{{code}}"
          />
          <view
            class="code-btn {{countdown > 0 ? 'code-btn--disabled' : ''}}"
            bindtap="sendCode"
          >
            <text>{{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}</text>
          </view>
        </view>
      </view>

      <button class="btn-primary login-btn" bindtap="register">
        <text>注 册</text>
      </button>

      <view class="register-link" bindtap="goLogin">
        <text class="register-text">已有账号？</text>
        <text class="register-link-text">返回登录</text>
      </view>
    </view>
  </view>
</scroll-view>
