page { background: #F5F7FA; }

.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  height: calc(44px + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  background: #1677FF;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  padding-right: 24rpx;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 44px;
  display: flex;
  align-items: center;
}

.nav-back-arrow {
  font-size: 48rpx;
  color: #fff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-selected {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  position: absolute;
  right: 24rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 地图 ---- */
.map-view {
  width: 100%;
  height: 45vh;
  flex-shrink: 0;
}

/* ---- 店铺面板 ---- */
.store-panel {
  flex: 1;
  background: #fff;
  display: flex;
  flex-direction: column;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  margin-top: -24rpx;
  overflow: hidden;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,.08);
}

.store-search {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F7FA;
  margin: 16rpx 24rpx 0;
  border-radius: 12rpx;
}

.search-icon-text {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.store-search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.store-search-placeholder {
  font-size: 26rpx;
  color: #BFBFBF;
}

.store-list-scroll {
  flex: 1;
  overflow-y: hidden;
}

.store-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 16rpx;
}

.store-item--active {
  background: #EFF6FF;
}

.store-icon { font-size: 40rpx; flex-shrink: 0; }

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.store-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.store-item--active .store-name {
  color: #1677FF;
}

.store-address {
  font-size: 24rpx;
  color: #999;
}

.store-distance {
  font-size: 22rpx;
  color: #BFBFBF;
}

.store-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1677FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-check text {
  font-size: 26rpx;
  color: #fff;
}

/* ---- 确认按钮 ---- */
.confirm-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.06);
}

.confirm-btn {
  background: #1677FF;
  color: #fff;
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  width: 100%;
}

.confirm-btn::after { border: none; }

.confirm-btn--disabled {
  background: #BFBFBF;
}
