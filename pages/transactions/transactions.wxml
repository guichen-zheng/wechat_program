<view class="page-root">
  <view class="nav-bar">
    <view class="nav-back" bindtap="onTapBack">
      <text class="nav-back-arrow">‹</text>
    </view>
    <text class="nav-title">交易记录</text>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker range="{{typeOptions}}" bindchange="onTypeChange">
      <view class="filter-item">
        <text class="filter-label">类型：</text>
        <text class="filter-val">{{filterType === 'all' ? '全部' : filterType === 'recharge' ? '充值' : '洗车'}} ›</text>
      </view>
    </picker>

    <view class="filter-divider"></view>

    <view class="filter-item filter-phone" wx:if="{{isAdmin}}">
      <text class="filter-label">手机号：</text>
      <input
        class="filter-input"
        type="number"
        maxlength="11"
        placeholder="输入手机号筛选"
        placeholder-class="filter-placeholder"
        bindinput="onPhoneInput"
        value="{{filterPhone}}"
      />
    </view>
  </view>

  <scroll-view scroll-y type="list" show-scrollbar="{{false}}" style="flex:1;overflow-y:hidden;">

    <!-- 空状态 -->
    <view wx:if="{{filteredList.length === 0}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无交易记录</text>
    </view>

    <!-- 列表 -->
    <view class="tx-list">
      <view
        wx:for="{{filteredList}}"
        wx:key="index"
        class="tx-item"
        bindtap="onTxTap"
        data-txid="{{item.id}}"
        data-phone="{{item.phone}}"
      >
        <view class="tx-icon {{item.type === 'recharge' ? 'tx-icon--green' : 'tx-icon--blue'}}">
          <text>{{item.type === 'recharge' ? '充' : '洗'}}</text>
        </view>
        <view class="tx-info">
          <text class="tx-desc">{{item.desc}}</text>
          <text class="tx-time">{{item.time}}</text>
          <text wx:if="{{isAdmin}}" class="tx-phone">{{item.phone}}</text>
        </view>
        <view class="tx-right">
          <text class="tx-amount {{item.amount > 0 ? 'tx-amount--green' : 'tx-amount--red'}}">
            {{item.amount > 0 ? '+¥' + item.amount : '-¥' + (-item.amount)}}
          </text>
          <text class="tx-arrow">›</text>
        </view>
      </view>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>
</view>
